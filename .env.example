# Instagram API (Instagram Login / Business Login flow)
# From your "Instagram" product page in the Meta Developer dashboard.
IG_LONG_LIVED_TOKEN=
IG_USER_ID=
IG_APP_ID=
IG_APP_SECRET=

# GitHub repo info (used to construct the public video URL the API fetches)
# e.g. owner/inkandexistence
GITHUB_REPO=
GITHUB_BRANCH=main

# Account display info (used in caption and watermark)
IG_HANDLE=@your_ig_handle
